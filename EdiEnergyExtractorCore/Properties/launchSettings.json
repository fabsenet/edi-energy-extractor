{
  "profiles": {
    "Without arguments (local rvn)": {
      "commandName": "Project",
      "commandLineArgs": ""
    },
    "dryrun": {
      "commandName": "Project",
      "commandLineArgs": "-dryrun true"
    },
    "dryrun+prefercache": {
      "commandName": "Project",
      "commandLineArgs": "-prefercache true -dryrun true"
    },
    "prefercache": {
      "commandName": "Project",
      "commandLineArgs": "-prefercache true"
    },
    "PROD update": {
      "commandName": "Project",
      "commandLineArgs": "",
      "environmentVariables": {
        "DOTNET_ENVIRONMENT": "Production"
      }
    }
  }
}